APP_NAME=shl-assessment-recommender
APP_ENV=development
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000

SHL_CATALOG_URL=https://www.shl.com/solutions/products/product-catalog/
RAW_CATALOG_PATH=data/raw/catalog.html
PROCESSED_CATALOG_PATH=data/processed/catalog.json
FAISS_INDEX_PATH=vectorstore/shl_catalog.faiss
FAISS_META_PATH=vectorstore/shl_catalog_meta.json

TOP_K_RETRIEVAL=20
TOP_K_RECOMMENDATIONS=10
MIN_RECOMMENDATIONS=1
MAX_TURNS=8

EMBEDDINGS_PROVIDER=sentence_transformers
EMBEDDINGS_MODEL=sentence-transformers/all-MiniLM-L6-v2
OPENAI_EMBEDDINGS_MODEL=text-embedding-3-small
OPENAI_API_KEY=

LLM_PROVIDER=none
LLM_MODEL=
GEMINI_API_KEY=
GROQ_API_KEY=
LLM_TEMPERATURE=0.2
LLM_TIMEOUT_SECONDS=20

HTTP_TIMEOUT_SECONDS=30
USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) SHL-Recommender/1.0
